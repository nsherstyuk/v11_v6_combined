# =============================================================
# IBKR + Grok Swing Trading Agent — Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================

# --- xAI / Grok API Key ---
XAI_API_KEY=your-xai-api-key-here

# --- Interactive Brokers Connection ---
IB_HOST=127.0.0.1
IB_PORT=4002          # 4002 = IB Gateway paper | 4001 = IB Gateway live | 7497 = TWS paper | 7496 = TWS live
IB_CLIENT_ID=1

# --- Trading Mode ---
PAPER_TRADING=true     # "true" for paper, "false" for live (BE VERY CAREFUL)

# --- Watchlist (comma-separated, optional — defaults defined in config.py) ---
# WATCHLIST=EEIQ,SGML,UGRO,ANET

# --- Timing ---
LOOP_INTERVAL_MINUTES=15

# --- Schedule (24h format, Eastern Time) ---
# Agent wakes up at ANALYSIS_START to call Grok for pre-market analysis.
# Orders are only placed during RTH (9:30 AM – 4:00 PM ET).
# Agent sleeps entirely outside this window (no Grok calls, no API cost).
ANALYSIS_START_HOUR=7         # 7 AM ET — Grok starts analyzing
ANALYSIS_START_MINUTE=0

# --- Risk Management ---
MAX_RISK_PER_TRADE=0.01     # 1% of account per trade
DAILY_LOSS_LIMIT=0.03       # 3% daily loss halts all trading
ACCOUNT_SIZE=10000           # Your paper/live account balance
CONFIDENCE_THRESHOLD=70      # Min Grok confidence to execute (0-100)

# --- Grok Model ---
GROK_MODEL=grok-4-1-fast-reasoning
